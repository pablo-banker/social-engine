# HTTP port the API listens on
PORT=8080

# Postgres connection string (used by golang-migrate and GORM)
DATABASE_URL=postgres://social:social@localhost:5432/social_engine?sslmode=disable

# Secret used to sign JWT access tokens (use a long random value in production)
JWT_SECRET=change-me

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
