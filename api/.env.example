# HTTP port the API listens on
PORT=8080

# Postgres connection string (used by golang-migrate and GORM)
DATABASE_URL=postgres://social:social@localhost:5432/social_engine?sslmode=disable

# Secret used to sign JWT access tokens. Must be at least 32 bytes — the API
# refuses to start with a missing or weak secret. Generate one with:
#   openssl rand -base64 32
JWT_SECRET=

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
